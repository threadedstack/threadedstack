{
  "name": "@tdsk/proxy",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup-node --config configs/tsup.config.ts",
    "start": "tsup --config ./configs/tsup.config.ts --watch ./src --watch ./configs --watch ../domain/src --watch ../logger/src --watch ../database/src --onSuccess 'pnpm serve'",
    "serve": "DEBUG=http-proxy-middleware* node --enable-source-maps dist/index.cjs",
    "d:build": "tsdown --config configs/tsdown.config.ts",
    "clean": "pnpm clean:dist && pnpm clean:nm",
    "clean:full": "pnpm clean",
    "clean:dist": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "docker:watch": "pnpm install && pnpm start",
    "d:start": "tsdown --config configs/tsdown.config.ts --watch ./src --watch ./configs --watch ../domain/src --watch ../logger/src --watch ../database/src --onSuccess 'pnpm serve'",
    "d:serve": "DEBUG=http-proxy-middleware* tsx -r ./configs/aliases.ts --enable-source-maps dist/index.cjs",
    "test": "vitest run --config configs/vitest.config.ts",
    "test:watch": "vitest --config configs/vitest.config.ts",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json",
    "types": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@keg-hub/jsutils": "10.0.0",
    "@keg-hub/parse-config": "2.2.0",
    "@tdsk/database": "workspace:*",
    "@tdsk/domain": "workspace:*",
    "@tdsk/logger": "workspace:*",
    "alias-hq": "6.2.4",
    "cors": "2.8.5",
    "express": "5.1.0",
    "express-async-handler": "1.2.0",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "http-proxy-middleware": "3.0.5",
    "jose": "6.1.3",
    "module-alias": "2.2.3",
    "tsup": "8.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.12.0",
    "tsdown": "0.20.2",
    "tsx": "4.21.0",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.1"
  }
}
