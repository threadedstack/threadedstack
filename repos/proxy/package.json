{
  "name": "@tdsk/proxy",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "bin": "dist/local.cjs",
  "scripts": {
    "build": "tsdown --config configs/tsdown.config.ts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "clean:full": "pnpm clean && pnpm clean:nm",
    "docker:watch": "pnpm install && pnpm start",
    "start": "tsdown --config configs/tsdown.config.ts --watch src  --watch configs --watch scripts --onSuccess 'pnpm serve'",
    "serve": "node --enable-source-maps dist/index.js",
    "test": "vitest run --config configs/vitest.config.ts",
    "test:watch": "vitest --config configs/vitest.config.ts",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json"
  },
  "dependencies": {
    "@keg-hub/jsutils": "10.0.0",
    "@keg-hub/parse-config": "2.2.0",
    "@tdsk/database": "workspace:*",
    "@tdsk/logger": "workspace:*",
    "@tdsk/domain": "workspace:*",
    "alias-hq": "6.2.4",
    "express": "4.21.2",
    "express-jwt": "8.5.1",
    "express-rate-limit": "7.5.0",
    "express-winston": "4.2.0",
    "jsonwebtoken": "9.0.2",
    "module-alias": "2.2.3",
    "tsup": "8.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.12.0",
    "esbuild": "0.19.3",
    "esbuild-register": "3.5.0",
    "tsconfig-paths": "4.2.0",
    "vitest": "^1.4.0",
    "vite-tsconfig-paths": "^4.3.1"
  }
}
