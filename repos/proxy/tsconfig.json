{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "target": "esnext",
    "jsx": "preserve",
    "module": "esnext",
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@PX/configs": ["configs"],
      "@PX/configs/*": ["configs/*"],
      "@PX": ["src"],
      "@PX/*": ["src/*"],
      "@ror/root/*": ["../../*"],
      "@ror/root": ["../../"],
      "@ror/deploy": ["../../deploy"],
      "@ror/deploy/*": ["../../deploy/*"],
      "@keg-hub/jsutils": ["node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["node_modules/@keg-hub/jsutils/build/esm/*"]
    }
  },
  "include": [
    "configs",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "build",
    "**/build/*",
    "node_modules",
    "**/node_modules/*",
    "dist",
    "**/dist/*"
  ]
}
