{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "target": "esnext",
    "jsx": "preserve",
    "module": "esnext",
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "esnext"],
    "forceConsistentCasingInFileNames": true,
    "paths": {

      "@TPX/configs": ["configs"],
      "@TPX/configs/*": ["configs/*"],
      "@TPX": ["src"],
      "@TPX/*": ["src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@TDB": ["../database/src"],
      "@TDB/*": ["../database/src/*"],
      "@TDB/configs": ["../database/configs"],
      "@TDB/configs/*": ["../database/configs/*"],
      "@tdsk/database": ["../database/src"],
      "@tdsk/database/*": ["../database/src/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"],

      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],

      "@keg-hub/jsutils": ["node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["node_modules/@keg-hub/jsutils/build/esm/*"]
    }
  },
  "include": [
    "configs",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "build",
    "**/build/*",
    "node_modules",
    "**/node_modules/*",
    "dist",
    "**/dist/*"
  ]
}
