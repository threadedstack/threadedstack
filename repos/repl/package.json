{
  "name": "@tdsk/repl",
  "version": "0.1.0",
  "description": "Terminal REPL for interacting with ThreadedStack AI agents",
  "type": "module",
  "bin": {
    "tsa": "./dist/tsa"
  },
  "scripts": {
    "serve": "./dist/tsa",
    "tsa": "./dist/tsa",
    "start": "bun --watch src/main.ts",
    "build": "bun run scripts/build.ts",
    "compile": "bun run scripts/build.ts --compile",
    "clean": "pnpm clean:dist && pnpm clean:nm",
    "clean:dist": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "clean:full": "pnpm clean",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json",
    "test": "vitest run --config configs/vitest.config.ts",
    "types": "tsc --noEmit --pretty"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@keg-hub/args-parse": "10.0.1",
    "@keg-hub/jsutils": "10.0.0",
    "@tdsk/agent": "workspace:*",
    "@tdsk/domain": "workspace:*",
    "@tdsk/sandbox": "workspace:*",
    "cli-highlight": "^2.1.11",
    "ink": "6.7.0",
    "ink-text-input": "6.0.0",
    "js-yaml": "4.1.1",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "picocolors": "1.1.1",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@types/bun": "1.3.9",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.12.0",
    "@types/react": "^19.0.0",
    "ink-testing-library": "4.0.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.1"
  }
}
