{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "strict": false,
    "allowJs": false,
    "outDir": "./dist",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "paths": {
      "@TSC": ["src"],
      "@TSC/*": ["src/*"],
      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],
      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["./node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["./node_modules/@keg-hub/jsutils/build/esm/node"]
    }
  },
  "include": ["src", "configs"],
  "exclude": [
    "build",
    "**/build/*",
    "node_modules",
    "**/node_modules/*",
    "dist",
    "**/dist/*"
  ]
}
