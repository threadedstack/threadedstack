{
  "name": "@tdsk/components",
  "description": "Threaded Stack components",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "tsup --config ./configs/tsup.config.ts",
    "build:watch": "tsup --watch --config ./configs/tsup.config.ts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "clean:full": "pnpm clean && pnpm clean:nm",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@emotion/react": "11.13.3",
    "@emotion/styled": "11.13.0",
    "@keg-hub/jsutils": "^10.0.0",
    "@monaco-editor/react": "4.6.0",
    "@mui/icons-material": "6.1.2",
    "@mui/lab": "6.0.0-beta.10",
    "@mui/material": "6.1.2",
    "mui-chips-input": "4.0.1",
    "mui-image-alter": "3.2.0",
    "overlayscrollbars": "2.11.0",
    "overlayscrollbars-react": "0.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-from-dom": "0.7.5",
    "react-resizable-panels": "3.0.1",
    "sonner": "^1.2.3",
    "split-pane-react": "0.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.53",
    "@types/react-dom": "^18.2.18",
    "glob": "10.3.10",
    "tsup": "^7.2.0",
    "typescript": "^5.3.3"
  }
}
