{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "target": "esnext",
    "module": "esnext",
    "noEmit": true,
    "allowJs": true,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "noImplicitAny": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {

      "@TAG/root": ["./"],
      "@TAG/root/*": ["./*"],
      "@TAG/dist": ["./dist"],
      "@TAG/dist/*": ["./dist/*"],
      "@TAG/configs": ["./configs"],
      "@TAG/configs/*": ["./configs/*"],
      "@TAG/": ["./src"],
      "@TAG/*": ["./src/*"],

      "@TSH": ["../shell/src"],
      "@TSH/*": ["../shell/src/*"],
      "@tdsk/shell": ["../shell/src"],
      "@tdsk/shell/*": ["../shell/src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@TWA": ["../wasm/src"],
      "@TWA/*": ["../wasm/src/*"],
      "@tdsk/wasm": ["../wasm/src"],
      "@tdsk/wasm/*": ["../wasm/src/*"],

      "@TDB": ["../database/src"],
      "@TDB/*": ["../database/src/*"],
      "@TDB/configs": ["../database/configs"],
      "@TDB/configs/*": ["../database/configs/*"],
      "@tdsk/database": ["../database/src"],
      "@tdsk/database/*": ["../database/src/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"],

      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],
      "@TSR/deploy": ["../../deploy"],
      "@TSR/deploy/*": ["../../deploy/*"],
      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["./node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["./node_modules/@keg-hub/jsutils/build/esm/node"]
    }
  },
  "include": [
    "src",
    "configs",
    "scripts",
    "../logger/src",
    "../domain/src",
    "../database/src"
  ]
}
