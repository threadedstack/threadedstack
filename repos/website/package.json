{
  "name": "@tdsk/website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build -c configs/vite.config.ts",
    "host": "vite --open --host -c configs/vite.config.ts",
    "clean": "pnpm clean:dist && pnpm clean:nm",
    "clean:full": "pnpm clean",
    "clean:dist": "rm -rf ./dist",
    "clean:nm": "rm -rf ./node_modules",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json",
    "preview": "vite preview -c configs/vite.config.ts",
    "start": "vite -c configs/vite.config.ts",
    "sf": "NODE_ENV=local vite -c configs/vite.config.ts",
    "test": "vitest run --config configs/vite.config.ts",
    "types": "tsc --noEmit --pretty",
    "screenshots": "npx tsx scripts/capture-screenshots.ts"
  },
  "optionalDependencies": {
    "playwright": "1.59.1"
  },
  "dependencies": {
    "@emotion/react": "11.13.3",
    "@emotion/styled": "11.13.0",
    "@keg-hub/jsutils": "^10.0.0",
    "@keg-hub/parse-config": "2.1.0",
    "@earendil-works/pi-web-ui": "0.75.3",
    "@mdx-js/react": "3.1.1",
    "@mdx-js/rollup": "3.1.1",
    "@mui/icons-material": "6.1.2",
    "@mui/lab": "6.0.0-beta.10",
    "@mui/material": "6.1.2",
    "@neondatabase/neon-js": "0.1.0-beta.21",
    "@tanstack/react-query": "5.90.16",
    "@tdsk/components": "workspace:*",
    "@tdsk/database": "workspace:*",
    "@tdsk/domain": "workspace:*",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "alias-hq": "6.2.4",
    "esbuild-register": "3.5.0",
    "github-slugger": "2.0.0",
    "jotai": "2.16.1",
    "mermaid": "11.12.3",
    "posthog-js": "1.242.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "3.0.0",
    "react-markdown": "10.1.0",
    "react-router": "7.1.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "4.0.1",
    "sonner": "2.0.7",
    "tsconfig-paths": "4.2.0",
    "unist-util-visit": "5.1.0",
    "vite": "^5.0.12",
    "vite-plugin-svgr-component": "1.0.1",
    "vite-tsconfig-paths": "4.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "14.6.1",
    "@types/mdast": "4.0.4",
    "@types/mdx": "2.0.13",
    "@types/node": "^20.11.16",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^24.0.0",
    "pagefind": "1.4.0",
    "remark": "15.0.1",
    "typescript": "^5.3.3",
    "vitest": "1.6.1"
  }
}
