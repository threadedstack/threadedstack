{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "target": "esnext",
    "module": "esnext",
    "noEmit": true,
    "allowJs": true,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "noImplicitAny": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {

      "@TSH/root": ["./"],
      "@TSH/root/*": ["./*"],
      "@TSH/dist": ["./dist"],
      "@TSH/dist/*": ["./dist/*"],
      "@TSH/configs": ["./configs"],
      "@TSH/configs/*": ["./configs/*"],
      "@TSH/": ["./src"],
      "@TSH/*": ["./src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@TWA": ["../wasm/src"],
      "@TWA/*": ["../wasm/src/*"],
      "@tdsk/wasm": ["../wasm/src"],
      "@tdsk/wasm/*": ["../wasm/src/*"],

      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],
      "@TSR/deploy": ["../../deploy"],
      "@TSR/deploy/*": ["../../deploy/*"],
      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["./node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["./node_modules/@keg-hub/jsutils/build/esm/node"]
    }
  },
  "include": [
    "src",
    "configs",
    "scripts",
    "../logger/src",
    "../domain/src",
    "../database/src"
  ],
  "exclude": [
    "src/polyfills/process.ts"
  ]
}
