{
  "name": "@tdsk/shell",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm build:app && pnpm build:shell",
    "build:app": "tsup-node --config configs/tsup.config.ts",
    "build:shell": "pnpm build:wasm shell",
    "build:wasm": "pnpm tsx scripts/wasm/build.ts",
    "wasm:deps": "pnpm tsx scripts/wasm/deps.ts",
    "postinstall": "pnpm wasm:deps && pnpm emsdk:setup",
    "emsdk:setup": "pnpm tsx scripts/wasm/emsdk.ts",
    "clean": "rm -rf dist",
    "clean:nm": "rm -rf node_modules",
    "clean:full": "pnpm clean && pnpm clean:nm",
    "start": "tsup --config ./configs/tsup.config.ts --watch ./src --watch ./configs --watch ../domain/src --watch ../logger/src --watch ../database/src --onSuccess 'pnpm serve'",
    "serve": "node --enable-source-maps dist/index.cjs",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json",
    "test": "vitest run --config configs/vitest.config.ts"
  },
  "dependencies": {
    "@keg-hub/jsutils": "^10.0.0",
    "@keg-hub/parse-config": "2.1.0",
    "@tdsk/domain": "workspace:*",
    "@tdsk/logger": "workspace:*",
    "@zenfs/core": "^1.0.5",
    "alias-hq": "6.2.2",
    "module-alias": "2.2.3",
    "tsx": "4.21.0",
    "vite-plugin-node-polyfills": "0.25.0",
    "web-streams-polyfill": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@types/node": "^20.11.16",
    "rimraf": "6.0.1",
    "tsup": "8.3.0",
    "typescript": "5.7.3",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.1"
  }
}
