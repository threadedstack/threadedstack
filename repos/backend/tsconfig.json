{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "target": "esnext",
    "module": "esnext",
    "noEmit": true,
    "allowJs": true,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "noImplicitAny": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "strictNullChecks": false,
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {

      "@TBE/configs": ["./configs"],
      "@TBE/configs/*": ["./configs/*"],
      "@TBE/public": ["./public"],
      "@TBE/public/*": ["./public/*"],
      "@TBE/": ["./src"],
      "@TBE/*": ["./src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@TDB": ["../database/src"],
      "@TDB/*": ["../database/src/*"],
      "@TDB/configs": ["../database/configs"],
      "@TDB/configs/*": ["../database/configs/*"],
      "@tdsk/database": ["../database/src"],
      "@tdsk/database/*": ["../database/src/*"],

      "@TAG": ["../agent/src"],
      "@TAG/*": ["../agent/src/*"],
      "@TAG/configs": ["../agent/configs"],
      "@TAG/configs/*": ["../agent/configs/*"],
      "@tdsk/agent": ["../agent/src"],
      "@tdsk/agent/*": ["../agent/src/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"],

      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],
      "@TSR/deploy": ["../../deploy"],
      "@TSR/deploy/*": ["../../deploy/*"],
      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["./node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["./node_modules/@keg-hub/jsutils/build/esm/node"]
    }
  },
  "include": [
    "src",
    "configs",
    "scripts",
    "../agent/src",
    "../logger/src",
    "../domain/src",
    "../database/src"
  ],
  "exclude": [
    "../agent/src/**/*.test.ts",
    "../agent/src/**/__tests__/**",
    "../agent/src/utils/logger.ts",
    "../agent/src/configs"
  ]
}
