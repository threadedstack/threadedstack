#! /usr/bin/env bash

# Ensure the TDSK_CLI_TASK_RUNNING env is unset when a tdsk task exits
unsetTdskTaskRunning(){
  unset TDSK_CLI_TASK_RUNNING
}

trap "unsetTdskTaskRunning" ERR

TDSK_SHELL_TYPE="$(ps -o comm= $$)"

# Check for the shell type
# Could be run in bash || zsh
if [[ "$TDSK_SHELL_TYPE" == "/bin/zsh" || "$TDSK_SHELL_TYPE" == "-zsh" ]]; then
  TDSK_IS_ZSH=1
else
  unset TDSK_IS_ZSH
fi

tdsk(){

  # Check if the tdsk-cli root dir has been set
  # If not set, then this code will find the root path based on the BASH_SOURCE[0] argument
  # Works when the tdsk-cli is symlinked into the /usr/local/bin
  if [[ -z "$TDSK_CLI_PATH" ]]; then
    # Get the tdsk-cli path based on the tdsk root directory
    local SOURCE
    if [[ "$TDSK_IS_ZSH" ]]; then
      SOURCE="${(%):-%x}"
    else
      SOURCE="$BASH_SOURCE"
    fi

    # Resolve $SOURCE until the file is no longer a symlink
    while [ -h "$SOURCE" ]; do
      TDSK_CLI_PATH="$(dirname "$SOURCE")"
      SOURCE="$(readlink "$SOURCE")"
      # If $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
      [[ $SOURCE != /* ]] && SOURCE="$TDSK_CLI_PATH/$SOURCE"
    done

    TDSK_CLI_PATH="$(dirname "$SOURCE")"
    export TDSK_CLI_PATH
  fi

  # Ensure the TDSK_REPO env exists
  if [[ -z "$TDSK_REPO" ]]; then
    export TDSK_REPO="$(dirname "$(dirname "$TDSK_CLI_PATH")")"
  fi


  # Shortcut to navigate to the tdsk directory
  if [[ -z "$2" ]]; then
    cd $TDSK_REPO
    return 0
  fi

  # Shortcut to open the tdsk directory in vscode
  if [[ "$1" == "open" ]]; then
    code $TDSK_REPO
    return 0
  fi

  # Execute the tdsk cli command
  (
    set -e

    # Set the env so we know a task is coming from the tdsk-cli and not locally
    export TDSK_CLI_TASK_RUNNING=1
    cd $TDSK_CLI_PATH
    # TODO: fix this, esbuild-register doesn't work with "type": "module" in package.json
    pnpm cli $@
    #node -r esbuild-register -r $TDSK_CLI_PATH/configs/aliases.ts $TDSK_CLI_PATH/src/index.ts $@

    TASK_RESP="$?"
    # Unset the TDSK_CLI_TASK_RUNNING env
    unsetTdskTaskRunning

    # return the exit code of the node tdsk-cli script
    return "$TASK_RESP"
  )

}

# --- Tab completion ---

# Resolve the CLI path from the completion function's own source file
# Uses TDSK_CLI_PATH as a fast path if already set from a prior tdsk call
_tdsk_resolve_cli_path(){
  if [[ -n "$TDSK_CLI_PATH" ]]; then
    echo "$TDSK_CLI_PATH"
    return
  fi

  local src
  if [[ "$TDSK_IS_ZSH" ]]; then
    src="${(%):-%x}"
  else
    src="${BASH_SOURCE[1]}"
  fi

  local resolved_dir
  while [ -h "$src" ]; do
    resolved_dir="$(dirname "$src")"
    src="$(readlink "$src")"
    [[ $src != /* ]] && src="$resolved_dir/$src"
  done

  dirname "$src"
}

_tdsk_completions(){
  local cli_path
  cli_path="$(_tdsk_resolve_cli_path)"
  local completions
  completions=$(
    cd "$cli_path" 2>/dev/null \
      && TDSK_COMP_LINE="$COMP_LINE" TDSK_COMP_POINT="$COMP_POINT" pnpm --silent cli 2>/dev/null
  )
  COMPREPLY=($(compgen -W "$completions" -- "${COMP_WORDS[COMP_CWORD]}"))
}

_tdsk_completions_zsh(){
  local cli_path
  cli_path="$(_tdsk_resolve_cli_path)"
  local line="${words[*]}"
  local point=${#line}
  local completions
  completions=$(
    cd "$cli_path" 2>/dev/null \
      && TDSK_COMP_LINE="$line" TDSK_COMP_POINT="$point" pnpm --silent cli 2>/dev/null
  )
  local -a matches
  matches=(${(f)completions})
  compadd -- $matches
}

if [[ "$TDSK_IS_ZSH" ]]; then
  # compdef requires compinit; ensure the completion system is loaded
  autoload -Uz compinit
  if ! (( $+functions[compdef] )); then
    compinit -i -C 2>/dev/null
  fi
  compdef _tdsk_completions_zsh tdsk
else
  complete -o default -F _tdsk_completions tdsk
fi