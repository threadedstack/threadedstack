{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "esnext",
    "outDir": "../dist",
    "rootDir": "../../",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "strictNullChecks": false,
    "moduleResolution": "bundler",
    "strictPropertyInitialization": false,
    "paths": {
      "@TIT/*": ["./src/*"],
      "@TIT": ["./src"],
      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],

      "@TSA": ["../tsa/src"],
      "@TSA/*": ["../tsa/src/*"],
      "@TSA/configs": ["../tsa/configs"],
      "@TSA/configs/*": ["../tsa/configs/*"],
      "@tdsk/tsa": ["../tsa/src"],
      "@tdsk/tsa/*": ["../tsa/src/*"],

      "@TAG": ["../agent/src"],
      "@TAG/*": ["../agent/src/*"],
      "@TAG/configs": ["../agent/configs"],
      "@TAG/configs/*": ["../agent/configs/*"],
      "@tdsk/agent": ["../agent/src"],
      "@tdsk/agent/*": ["../agent/src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@TSB": ["../sandbox/src"],
      "@TSB/*": ["../sandbox/src/*"],
      "@tdsk/sandbox": ["../sandbox/src"],
      "@tdsk/sandbox/*": ["../sandbox/src/*"],

      "@TDB": ["../database/src"],
      "@TDB/*": ["../database/src/*"],
      "@tdsk/database": ["../database/src"],
      "@tdsk/database/*": ["../database/src/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"]
    }
  },
  "include": [
    "./configs",
    "./src/**/*.ts",
    "./playwright/**/*.ts"
  ]
}
