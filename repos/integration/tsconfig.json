{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist",
    "rootDir": ".",
    "paths": {
      "@TIT/*": ["./src/*"],
      "@TIT": ["./src"],
      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"]
    }
  },
  "include": [
    "./configs",
    "./src/**/*.ts",
    "./playwright/**/*.ts"
  ]
}
