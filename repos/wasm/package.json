{
  "name": "@tdsk/wasm",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./run": {
      "types": "./dist/run/helper.d.ts",
      "import": "./dist/run/helper.js"
    }
  },
  "scripts": {
    "build": "tsup-node --config configs/tsup.config.ts",
    "jco": "jco",
    "clean": "rm -rf dist",
    "script": "tsx scripts/script.ts",
    "lint": "biome lint --config-path $(pwd)/configs/biome.json --write",
    "format": "biome format --config-path $(pwd)/configs/biome.json --write",
    "test": "vitest run --config configs/vitest.config.ts",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@bytecodealliance/componentize-js": "0.19.3",
    "@bytecodealliance/jco": "1.15.4",
    "@bytecodealliance/preview2-shim": "0.17.7",
    "@keg-hub/jsutils": "^10.0.0",
    "esbuild": "0.27.2",
    "pako": "2.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@types/node": "^25.2.0",
    "@types/pako": "2.0.4",
    "tsup": "8.3.0",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.1"
  }
}
