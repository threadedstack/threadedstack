{
  "name": "@tdsk/database",
  "version": "0.1.0",
  "description": "Database",
  "main": "index.js",
  "author": "Lance Tipton",
  "license": "ISC",
  "keywords": [],
  "private": true,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rm -rf ./node_modules",
    "dk": "drizzle-kit",
    "script": "STL_FORCE_DISABLE_SAFE=1 tsx -r ./configs/aliases.ts scripts/script.ts",
    "generate": "drizzle-kit generate --config=configs/drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config=configs/drizzle.config.ts",
    "introspect": "drizzle-kit introspect --config=configs/drizzle.config.ts",
    "push": "drizzle-kit push --config=configs/drizzle.config.ts",
    "studio": "drizzle-kit studio --config=configs/drizzle.config.ts",
    "dup": "drizzle-kit up --config=configs/drizzle.config.ts",
    "check": "drizzle-kit check --config=configs/drizzle.config.ts",
    "drop": "drizzle-kit drop --config=configs/drizzle.config.ts",
    "export": "drizzle-kit export --config=configs/drizzle.config.ts",
    "seed": "tsx -r ./configs/aliases.ts scripts/seed.ts",
    "purge": "tsx -r ./configs/aliases.ts scripts/purge.ts",
    "biome": "biome",
    "lint": "pnpm biome:lint --write",
    "format": "pnpm biome:format --write",
    "lint:ci": "pnpm biome:lint --diagnostic-level=error --changed",
    "format:ci": "pnpm biome:format --diagnostic-level=error --changed",
    "lint:staged": "pnpm biome:lint --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "format:staged": "pnpm biome:format --diagnostic-level=error --staged --no-errors-on-unmatched --write",
    "biome:lint": "biome lint --config-path $(pwd)/configs/biome.json",
    "biome:format": "biome format --config-path $(pwd)/configs/biome.json",
    "test": "vitest run --config configs/vitest.config.ts"
  },
  "dependencies": {
    "@keg-hub/jsutils": "10.0.0",
    "@keg-hub/parse-config": "2.2.0",
    "@tdsk/domain": "workspace:*",
    "@tdsk/logger": "workspace:*",
    "alias-hq": "6.2.4",
    "drizzle-orm": "0.45.1",
    "module-alias": "2.2.3",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "drizzle-kit": "0.31.8",
    "tsx": "4.21.0",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.1"
  }
}
