{
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "strict": false,
    "allowJs": true,
    "target": "esnext",
    "outDir": "./dist",
    "module": "esnext",
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@ROOT": ["../../"],

      "@TDB": ["./src"],
      "@TDB/*": ["./src/*"],
      "@TDB/configs": ["./configs"],
      "@TDB/configs/*": ["./configs/*"],
      "@TDB/drizzle": ["./drizzle"],
      "@TDB/drizzle/*": ["./drizzle/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"],

      "@tdsk/domain/web": ["../domain/src/web.ts"],

      "@keg-hub/jsutils": ["node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["node_modules/@keg-hub/jsutils/build/esm/node"]
    },
  },
  "include": [
    "src",
    "configs",
    "scripts"
  ]
}
