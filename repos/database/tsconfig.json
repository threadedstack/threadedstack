{
  "parserOptions": {
    "extraFileExtensions": ["json"]
  },
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "./dist",
    "target": "esnext",
    "module": "esnext",
    "noEmit": true,
    "allowJs": true,
    "sourceMap": true,
    "declaration": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "noImplicitAny": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {

      "@TDB/root": ["./"],
      "@TDB/configs": ["./configs"],
      "@TDB/configs/*": ["./configs/*"],
      "@TDB/drizzle": ["./drizzle"],
      "@TDB/drizzle/*": ["./drizzle/*"],
      "@TDB": ["./src"],
      "@TDB/*": ["./src/*"],

      "@tdsk/logger": ["../logger/src"],
      "@tdsk/logger/*": ["../logger/src/*"],

      "@TDM": ["../domain/src"],
      "@TDM/*": ["../domain/src/*"],
      "@tdsk/domain": ["../domain/src"],
      "@tdsk/domain/*": ["../domain/src/*"],

      "@ROOT": ["../../"],
      "@ROOT/*": ["../../*"],

      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/esm"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/esm/*"],
      "@keg-hub/jsutils/src/node": ["./node_modules/@keg-hub/jsutils/build/esm/node"],
      "@keg-hub/jsutils/src/node/*": ["./node_modules/@keg-hub/jsutils/build/esm/node"]
    }
  },
  "include": [
    "src",
    "configs",
    "scripts",
    "../logger/src",
    "../domain/src"
  ]
}
