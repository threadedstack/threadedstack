{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(jq:*)",
      "Bash(tsx:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(which:*)",
      "Bash(pnpm:*)",
      "Bash(curl:*)",
      "Bash(kill:*)",
      "Bash(lsof:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(tdsk:*)",
      "Bash(npx playwright:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(pnpm lint)",
      "Bash(pnpm biome:lint)",
      "Bash(pnpm format)",
      "Bash(pnpm biome:format)"
    ]
  },
  "includeCoAuthoredBy": false,
  "enabledMcpjsonServers": []
}
