{
  "env": {
  },
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(jq:*)",
      "Bash(tsx:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",
      "Bash(git:*)",
      "Bash(which:*)",
      "Bash(pnpm:*)",
      "Bash(mcp__happy__change_title:*)",
      "Bash(mkdir -p /Users/LanceTipton/keg-cli/external/apps/threaded-stack/:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(pnpm lint)",
      "Bash(pnpm biome:lint)",
      "Bash(pnpm format)",
      "Bash(pnpm biome:format)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE_PATH\" in *pnpm-lock.yaml|*.env|*.env.*|*values.production.yaml) echo 'BLOCK: Protected file - do not edit lock files, .env files, or production values directly' >&2; exit 2;; esac"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "enabledMcpjsonServers": []
}
