FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    openssh-server git curl ca-certificates sudo \
    && rm -rf /var/lib/apt/lists/*

# Create sandbox user with home directory
RUN useradd -m -s /bin/bash sandbox \
    && mkdir -p /run/sshd /workspace \
    && chown sandbox:sandbox /workspace

# SSH config: password auth on port 2222, no root login
RUN sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config \
    && echo "Port 2222" >> /etc/ssh/sshd_config

# Generate host keys at build time so sshd starts without delay
RUN ssh-keygen -A

# Node.js 22 + AI agents and tools (Claude Code, Codex, OpenClaw, Pi Coding Agent)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g @anthropic-ai/claude-code @openai/codex openclaw@latest \
    && npm install -g --ignore-scripts @earendil-works/pi-coding-agent \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI (official apt repo: keyring + apt source + gh)
RUN mkdir -p -m 755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# pnpm via corepack — bake the REPO-PINNED version (package.json's packageManager
# field) at build time so no pod ever downloads pnpm at runtime. Preparing
# `pnpm@latest` was a latent bug: it mismatched the repo pin, so corepack re-fetched
# the pinned version at runtime through the egress MITM proxy, which crashes Node's
# undici HTTP parser (assert(!this.paused)) and leaves the resident runtime unbuilt
# (a permanent crash loop). Reading packageManager keeps this in lockstep with the
# repo — a root package.json change already rebuilds this image (changedContexts),
# so there is no version to drift. A shared COREPACK_HOME lets BOTH root (the
# resident launcher) and the sandbox user (the setup script) hit one prewarmed
# cache — verified offline, cross-user (--network none, both users). It is
# `chown`ed to the sandbox user (NOT left root-read-only): the baked pin still
# cache-hits, but a project pinning a DIFFERENT pnpm can still fall back to a
# writable per-user download instead of failing hard with EACCES.
ENV COREPACK_HOME=/usr/local/corepack
COPY package.json /tmp/tdsk-corepack/package.json
RUN corepack enable \
    && cd /tmp/tdsk-corepack \
    && COREPACK_ENABLE_DOWNLOAD_PROMPT=0 corepack prepare --activate \
    && chown -R sandbox:sandbox "$COREPACK_HOME" \
    && chmod -R a+rX "$COREPACK_HOME" \
    && rm -rf /tmp/tdsk-corepack

# Antigravity CLI (standalone Go binary)
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash \
    && cp /root/.local/bin/agy /usr/local/bin/agy \
    && chmod +x /usr/local/bin/agy


# Pre-bake Mutagen agent for file sync
# Install the platform-specific npm package, extract the agent binary
# from its bundled mutagen-agents.tar.gz, place it where the daemon expects it
ARG TARGETARCH
ARG TDSK_SB_HOME=/home/sandbox
RUN NPM_ARCH="${TARGETARCH:-arm64}" \
    && if [ "$NPM_ARCH" = "amd64" ]; then NPM_ARCH="x64"; fi \
    && MUTAGEN_PKG="@nuanced-dev/mutagen-linux-${NPM_ARCH}" \
    && MUTAGEN_VER=$(npm show "$MUTAGEN_PKG" version 2>/dev/null) \
    && npm pack "$MUTAGEN_PKG" --pack-destination /tmp \
    && tar xzf /tmp/nuanced-dev-mutagen-linux-*.tgz -C /tmp \
    && AGENTS_BUNDLE="/tmp/package/bin/mutagen-agents.tar.gz" \
    && AGENT_DIR="${TDSK_SB_HOME}/.mutagen-dev/agents/${MUTAGEN_VER}" \
    && mkdir -p "$AGENT_DIR" \
    && tar xzf "$AGENTS_BUNDLE" -C /tmp "linux_${TARGETARCH:-arm64}" \
    && mv "/tmp/linux_${TARGETARCH:-arm64}" "$AGENT_DIR/mutagen-agent" \
    && chmod 700 "$AGENT_DIR/mutagen-agent" \
    && chown -R sandbox:sandbox "$TDSK_SB_HOME/.mutagen-dev" \
    && rm -rf /tmp/nuanced-dev-* /tmp/package /tmp/linux_*

# OpenCode binary (tarball, multi-arch)
ARG OPENCODE_ARCH=${TARGETARCH}
RUN if [ "$OPENCODE_ARCH" = "amd64" ]; then OPENCODE_ARCH="x86_64"; fi \
    && curl -fsSL https://github.com/opencode-ai/opencode/releases/latest/download/opencode-linux-${OPENCODE_ARCH}.tar.gz \
    | tar xz -C /usr/local/bin opencode \
    && chmod +x /usr/local/bin/opencode

# CA cert mount point for MITM proxy trust (runtime-only: the cert itself is
# injected by a K8s Secret volume mount at pod start, never baked into the
# image — see repos/sandbox/src/kube/podManifest.ts). Declared after every
# node/npm-invoking build step above so those steps don't try to load a cert
# file that doesn't exist yet in the build context and log
# "Ignoring extra certs ... load failed: No such file or directory" noise.
ENV NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/tdsk-proxy.crt

COPY deploy/sandbox-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 2222
WORKDIR /workspace

ENTRYPOINT ["entrypoint.sh"]
CMD ["sleep", "infinity"]
