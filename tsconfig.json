{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "allowJs": true,
    "rootDir": "./",
    "target": "esnext",
    "outDir": "./dist",
    "module": "esnext",
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@keg-hub/jsutils": ["./node_modules/@keg-hub/jsutils/build/cjs"],
      "@keg-hub/jsutils/*": ["./node_modules/@keg-hub/jsutils/build/cjs/*"]
    },
  },
  "include": [
    "scripts",
    "configs"
  ],
  "exclude": [
    "repos"
  ]
}
